[Unit]
Description=Status probe agent (Olfe / Incinet)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Root: ICMP ping needs raw sockets / setuid ping on most VPS
User=root
Group=root
EnvironmentFile=/etc/status-agent/agent.env
ExecStart=/usr/local/bin/status-agent
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
